{
  "layer": "top",
  "height": 24,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-right": [
    "custom/notification",
    "cpu",
    "memory",
    "disk",
    "backlight",
    "pulseaudio#microphone",
    "pulseaudio",
    "battery",
    "clock",
    "custom/recording",
    "tray"
  ],
  "hyprland/window": {
    "format": "{}"
  },
  "cpu": {
    "interval": 10,
    "format": "[<span color='#cba6f7'>п‹› </span>{usage}%]",
    "max-length": 10,
    "on-click": "kitty --start-as=fullscreen --title btop sh -c 'btop'"
  },
  "disk": {
    "interval": 30,
    "format": "[<span color='#94e2d5'>у°‹Љ </span>{percentage_used}%]",
    "path": "/",
    "tooltip": true,
    "tooltip-format": "HDD - {used} used out of {total} on {path} ({percentage_used}%)",
    "on-click": "kitty --start-as=fullscreen --title btop sh -c 'btop'"
  },
  "memory": {
    "interval": 30,
    "format": "[<span color='#eba0ac'>пѓ‰ </span>{}%]",
    "max-length": 10,
    "tooltip": true,
    "tooltip-format": "Memory - {used:0.1f}GB used",
    "on-click": "kitty --start-as=fullscreen --title btop sh -c 'btop'"
  },
  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {
      "eDP-1": 9
    }
  },
  "tray": {
    "icon-size": 12,
    "spacing": 6,
    "reverse-direction": true
  },
  "clock": {
    "format": "[{:%H:%M}]",
    "format-alt": "[{:%a %d %b}]",
    "tooltip-format": "<tt><small>{calendar}</small></tt>"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "[<span color='#f9e2af'>{icon}</span> {percent}%]",
    "format-icons": ["у°ѓћ", "у°ѓџ", "у°ѓ "]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "[<span color='#a6e3a1'>{icon}</span> {capacity}%]",
    "format-charging": "[вљЎ{capacity}%]",
    "format-plugged": "[п‡¦ {capacity}%]",
    "format-alt": "{time} {icon}",
    "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"]
  },
  "pulseaudio": {
    "format": "[<span color='#89b4fa'>{icon}</span> {volume}%]",
    "format-muted": "[<span color='#585b70'>у°ќџ</span>]",
    "on-click": "pamixer -t",
    "on-click-right": "pavucontrol",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "пЂҐ",
      "hands-free": "пЂҐ",
      "headset": "пЂҐ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№",
      "default": ["пЂ¦", "пЂ§", "пЂЁ"]
    }
  },
  "pulseaudio#microphone": {
    "format": "[{format_source}]",
    "format-source": "<span color='#cba6f7'>п„° </span>{volume}%",
    "format-source-muted": "<span color='#585b70'>п„±</span>",
    "on-click": "pamixer --default-source -t",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pamixer --default-source -i 5",
    "on-scroll-down": "pamixer --default-source -d 5",
    "scroll-step": 5
  },
  "custom/notification": {
    "tooltip": false,
    "format": "[{icon}]",
    "format-icons": {
      "notification": "рџ””<span foreground='red'><sup>п‘„</sup></span>",
      "none": "рџ””",
      "dnd-notification": "рџ”•<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-none": "рџ”•",
      "inhibited-notification": "рџ””<span foreground='red'><sup>п‘„</sup></span>",
      "inhibited-none": "рџ””",
      "dnd-inhibited-notification": "рџ”•<span foreground='red'><sup>п‘„</sup></span>",
      "dnd-inhibited-none": "рџ”•"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/recording": {
    "exec": "exec ~/.scripts/record-screend",
    "exec-on-event": false,
    "on-click": "pkill -INT -P \"$(pgrep -xo record-screen)\" wf-recorder"
  }
}
